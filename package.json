{
  "name": "ly-tools",
  "version": "1.0.0",
  "description": "实用小工具集 - 端口查杀 & 图标生成",
  "author": "屈想顺",
  "license": "AGPL-3.0",
  "main": "dist-electron/main.js",
  "build": {
    "afterPack": "scripts/afterPack.js",
    "productName": "栾媛小工具",
    "icon": "build/icon.ico",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "栾媛小工具",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "include": "nsis/installer.nsh"
    }
  },
  "scripts": {
    "dev": "node scripts/build-icon.js && vite",
    "build": "node scripts/build-icon.js && vite build && node -e \"require('fs').copyFileSync('build/icon.ico','dist/icon.ico')\" && electron-builder && node scripts/apply-exe-icon.mjs",
    "preview": "vite preview",
    "generate:index": "node scripts/generate-plugin-index.js"
  },
  "dependencies": {
    "@iconify/vue": "^4.1.0",
    "adm-zip": "^0.5.16",
    "element-plus": "^2.9.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0"
  }
}
